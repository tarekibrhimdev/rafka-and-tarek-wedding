<?xml version="1.0" encoding="utf-8"?>
<!--
  Published with the app so IIS can redirect native 403 responses to login (in addition to ASP.NET Core UseStatusCodePages).
  Adjust hostingModel (inprocess vs outofprocess) if your IIS host requires it.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\WeddingInvitation.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess" />
      <!-- IIS-generated 403 (permissions, handler failure, etc.) → login -->
      <httpErrors errorMode="Custom" existingResponse="Replace">
        <remove statusCode="403" />
        <error statusCode="403" path="/Account/Login" responseMode="Redirect" />
      </httpErrors>
    </system.webServer>
  </location>
</configuration>
