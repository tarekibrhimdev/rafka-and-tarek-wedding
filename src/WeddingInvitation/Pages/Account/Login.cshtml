@page
@model WeddingInvitation.Pages.Account.LoginModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Sign in";
}

<h1 class="h4 fw-bold mb-1">Wedding admin</h1>
<p class="text-muted small mb-4">Sign in to manage guests and invitations.</p>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger small py-2" role="alert">@Model.ErrorMessage</div>
}

<form method="post">
    @if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
    {
        <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
    }
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
    <div class="mb-3">
        <label asp-for="Input.UserName" class="form-label small fw-semibold"></label>
        <input asp-for="Input.UserName" class="form-control form-control-lg" autocomplete="username" autocapitalize="none" />
        <span asp-validation-for="Input.UserName" class="text-danger small"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Input.Password" class="form-label small fw-semibold"></label>
        <input asp-for="Input.Password" class="form-control form-control-lg" autocomplete="current-password" />
        <span asp-validation-for="Input.Password" class="text-danger small"></span>
    </div>
    <div class="form-check mb-4">
        <input asp-for="Input.RememberMe" class="form-check-input" />
        <label asp-for="Input.RememberMe" class="form-check-label small"></label>
    </div>
    <button type="submit" class="btn btn-admin-primary w-100 btn-lg">Sign in</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
