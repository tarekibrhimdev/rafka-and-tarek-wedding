@page
@model WeddingInvitation.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Overview";
}

<div class="admin-page-header">
    <div>
        <h1 class="admin-page-title">Overview</h1>
        <p class="admin-page-subtitle text-muted">Quick snapshot of your wedding guest list and RSVPs.</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card admin-card stat-card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase fw-semibold letter-spacing">Guests</div>
                <div class="display-6 fw-semibold mt-2">@Model.TotalGuests</div>
                <div class="small text-muted mt-1">Active household records</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card admin-card stat-card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase fw-semibold letter-spacing">Invitations</div>
                <div class="display-6 fw-semibold mt-2">@Model.InvitationsIssued</div>
                <div class="small text-muted mt-1">Links generated</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card admin-card stat-card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase fw-semibold letter-spacing">RSVP pending</div>
                <div class="display-6 fw-semibold mt-2">@Model.PendingRsvps</div>
                <div class="small text-muted mt-1">Awaiting guest response</div>
            </div>
        </div>
    </div>
</div>

<div class="card admin-card shadow-sm mt-4">
    <div class="card-body d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <h2 class="h5 fw-semibold mb-1">Guest list</h2>
            <p class="text-muted small mb-0">Create guests, add household names, and generate invitation URLs.</p>
        </div>
        <a class="btn btn-admin-primary" asp-page="/Admin/Guests/Index">Open guests</a>
    </div>
</div>
