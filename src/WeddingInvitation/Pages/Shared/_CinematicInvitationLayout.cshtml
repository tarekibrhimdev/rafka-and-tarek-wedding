@using System.Text.Json
<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=1, user-scalable=no" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="theme-color" content="#ebe4d6" />
    <meta name="description" content="Wedding invitation" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700;1,400&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Instrument+Serif:ital@0;1&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/cinematic-invite/vendor/swiper/swiper-bundle.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/cinematic-invite/css/styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/cinematic-invite/css/animations.css" asp-append-version="true" />
</head>
<body>
@{
    var cinBase = (Url.Content("~/cinematic-invite") ?? "").TrimEnd('/');
}
<script>
    window.CIN_BASE = @Html.Raw(JsonSerializer.Serialize(cinBase));
</script>
    @RenderBody()
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
